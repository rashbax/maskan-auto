# ── Supabase ────────────────────────────────────────────────
# Project Settings → API. Copy these into a local .env.local (never commit .env.local).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
# Server-only secret (used for admin tasks / seeding). NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# ── Site ────────────────────────────────────────────────────
# Public site origin. Pins the Telegram magic-link redirect to a trusted host.
SITE_URL=https://maskan-auto.vercel.app
# Shared secret for Vercel Cron → /api/cron/booking-sync (Vercel sends it as a Bearer token).
CRON_SECRET=

# ── Yandex Maps ─────────────────────────────────────────────
# JS API key — used client-side; restrict it by domain in the Yandex dashboard.
NEXT_PUBLIC_YANDEX_API_KEY=YOUR-YANDEX-JS-API-KEY

# ── Telegram (login bot + owner notifications) — leave EMPTY to keep disabled ──
TELEGRAM_BOT_TOKEN=        # server-only secret
TELEGRAM_BOT_USERNAME=    # public bot username, e.g. maskan_tashkentbot (login deep links)
TELEGRAM_WEBHOOK_SECRET=  # webhook secret_token (fail-closed)
TELEGRAM_OWNER_CHAT_ID=   # chat that receives new-booking notices
TELEGRAM_OWNER_CONTACT=   # host's personal Telegram for the hand-off button (@user or +phone)
WEBHOOK_URL=             # public webhook URL for scripts/tg-setwebhook.mjs (e.g. https://.../api/telegram/webhook)

# ── Beds24 channel manager (two-way sync) — leave EMPTY to keep disabled ──
BEDS24_REFRESH_TOKEN=    # long-lived; from the one-time invite-code exchange
BEDS24_DIAG_KEY=        # gates /api/beds24/diag (setup + smoke test)
# BEDS24_API_BASE=https://api.beds24.com/v2   # optional override (defaults to this)

# ── Cloudflare R2 (photos) — when wired up ──────────────────
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_URL=
