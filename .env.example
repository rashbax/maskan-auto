# ── Supabase ────────────────────────────────────────────────
# Project Settings → API. Copy these into a local .env.local (never commit .env.local).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
# Server-only secret (used for admin tasks / seeding). NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# ── Site ────────────────────────────────────────────────────
# Public site origin. Pins the Telegram magic-link redirect to a trusted host.
SITE_URL=https://maskan-auto.vercel.app

# ── Yandex Maps ─────────────────────────────────────────────
# JS API key — used client-side; restrict it by domain in the Yandex dashboard.
NEXT_PUBLIC_YANDEX_API_KEY=YOUR-YANDEX-JS-API-KEY

# ── Telegram (login bot + owner notifications) ──────────────
TELEGRAM_BOT_TOKEN=YOUR-BOT-TOKEN            # server-only secret
TELEGRAM_BOT_USERNAME=maskan_tashkentbot     # public bot username (login deep links)
TELEGRAM_WEBHOOK_SECRET=YOUR-WEBHOOK-SECRET  # set as the webhook secret_token (fail-closed)
TELEGRAM_OWNER_CHAT_ID=YOUR-OWNER-CHAT-ID    # where new-booking notices are sent
TELEGRAM_OWNER_CONTACT=+998940026056         # host's personal Telegram for the hand-off button (@user or +phone)

# ── Beds24 channel manager (two-way sync) ───────────────────
BEDS24_REFRESH_TOKEN=YOUR-BEDS24-REFRESH-TOKEN  # long-lived; from the one-time invite-code exchange
BEDS24_DIAG_KEY=YOUR-DIAG-SECRET                # gates /api/beds24/diag (setup + smoke test)
# BEDS24_API_BASE=https://api.beds24.com/v2     # optional override (defaults to this)

# ── Cloudflare R2 (photos) — when wired up ──────────────────
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_URL=
