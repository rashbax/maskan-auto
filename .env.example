# ── Supabase ────────────────────────────────────────────────
# Project Settings → API. Copy these into a local .env.local (never commit .env.local).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
# Server-only secret (used for admin tasks / seeding). NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

